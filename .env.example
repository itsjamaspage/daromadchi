# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App URL ──────────────────────────────────────────────────────────────────
# Your deployed domain (no trailing slash)
NEXT_PUBLIC_APP_URL=https://daromadchi.uz
NEXT_PUBLIC_SITE_URL=https://daromadchi.uz

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-256-CBC key for encrypting marketplace API tokens stored in DB
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-key-here

# ─── Cron jobs ────────────────────────────────────────────────────────────────
# Secret header value for /api/cron/* routes (set same value in Vercel cron config)
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# ─── Telegram bot ─────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff-your-token
TELEGRAM_BOT_USERNAME=your_bot_username
# Random secret for validating Telegram webhook POSTs (32–256 chars)
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-here

# ─── Payme (payment provider) ─────────────────────────────────────────────────
# Get from: Payme merchant cabinet
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_SECRET_KEY=your-payme-secret-key

# ─── Click (payment provider) ─────────────────────────────────────────────────
# Get from: Click merchant cabinet
CLICK_SERVICE_ID=your-click-service-id
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SECRET_KEY=your-click-secret-key
