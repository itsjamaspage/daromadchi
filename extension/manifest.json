{
  "manifest_version": 3,
  "name": "Daromadchi — Uzum, Yandex & Wildberries Analytics",
  "version": "2.3.0",
  "description": "Uzum, Yandex Market va Wildberries sotuvchilari uchun aqlli tahlil: marja, ROI, reklama samaradorligi",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://daromadchi.uz/*",
        "https://www.daromadchi.uz/*"
      ],
      "js": ["content-daromadchi.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://uzum.uz/*",
        "https://www.uzum.uz/*",
        "*://*.uzum.uz/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://partner.market.yandex.ru/*",
        "https://market.yandex.ru/*",
        "https://market.yandex.uz/*"
      ],
      "js": ["content-yandex.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://seller.wildberries.ru/*",
        "https://seller-weekly-report.wildberries.ru/*",
        "https://www.wildberries.uz/*",
        "https://wildberries.uz/*",
        "https://www.wildberries.ru/*",
        "https://wildberries.ru/*"
      ],
      "js": ["content-wb.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "alarms", "notifications", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "*://*.uzum.uz/*",
    "https://uzum.uz/*",
    "https://partner.market.yandex.ru/*",
    "https://market.yandex.ru/*",
    "https://market.yandex.uz/*",
    "https://api.partner.market.yandex.ru/*",
    "https://daromadchi.uz/*",
    "https://www.daromadchi.uz/*",
    "https://common-api.wildberries.ru/*",
    "https://statistics-api.wildberries.ru/*",
    "https://suppliers-api.wildberries.ru/*",
    "https://seller.wildberries.ru/*",
    "https://www.wildberries.uz/*",
    "https://wildberries.uz/*",
    "https://www.wildberries.ru/*",
    "https://wildberries.ru/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
