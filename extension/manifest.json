{
  "manifest_version": 3,
  "name": "Daromadchi — Uzum & Yandex Market Analytics",
  "version": "2.1.0",
  "description": "Uzum va Yandex Market sotuvchilari uchun aqlli tahlil: marja, ROI, reklama samaradorligi",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://uzum.uz/*",
        "https://www.uzum.uz/*",
        "*://*.uzum.uz/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://partner.market.yandex.ru/*"
      ],
      "js": ["content-yandex.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "alarms", "notifications", "activeTab"],
  "host_permissions": [
    "*://*.uzum.uz/*",
    "https://uzum.uz/*",
    "https://partner.market.yandex.ru/*",
    "https://daromadchi.uz/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
